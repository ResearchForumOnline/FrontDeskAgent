[Unit]
Description=FrontDeskAgent self-hosted AI receptionist
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/frontdeskagent
EnvironmentFile=%h/frontdeskagent/.env
ExecStart=%h/frontdeskagent/.venv/bin/gunicorn -b 0.0.0.0:8088 frontdeskagent.app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
